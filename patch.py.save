import re
with open("frontend/app/layout.tsx", "r") as f:
    text = f.read()

# Add a cool macOS abstract gradient background to body
apple_bg = """          body {
            margin: 0;
            padding: 0;
            font-family: -apple-system, BlinkMacSystemFont, "SF Pro Display", "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
            background: linear-gradient(-45deg, #e0eafc, #cfdef3, #d4fc79, #96e6a1);
            background-size: 400% 400%;
            animation: gradientBG 15s ease infinite;
            color: #1d1d1f;
            -webkit-font-smoothing: antialiased;
            letter-spacing: -0.015em;
            min-height: 100vh;
          }
          @keyframes gradientBG {
            0% { background-position: 0% 50%; }
            50% { background-position: 100% 50%; }
            100% { background-position: 0% 50%; }
          }"""

text = re.sub(r'          body \{.+?letter-spacing: -0\.015em;\n          \}', apple_bg, text, flags=re.DOTALL)

with open("frontend/app/layout.tsx", "w") as f:
    f.write(text)
EOF
