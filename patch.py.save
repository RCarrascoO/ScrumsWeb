cat << 'EOF' > patch_prompts.py
import re
import sys

def apply_patch():
    file_path = "frontend/app/projects/[id]/sprints/[sprintId]/page.tsx"
    with open(file_path, "r") as f:
        content = f.read()

    # We need to add state for the custom prompt
    if "const [promptConfig, setPromptConfig] = useState" not in content:
        state_decl = """  const [showAssignModalForTask, setShowAssignModalForTask] = useState<number | null>(null);
  const [promptConfig, setPromptConfig] = useState<{isOpen: boolean, title: string, defaultValue: string, onConfirm: (val: string) => void} | null>(null);
"""
        content = content.replace("  const [showAssignModalForTask, setShowAssignModalForTask] = useState<number | null>(null);\n", state_decl)

    # Add the prompt modal UI before the final </main> OR in the return
    if "promptConfig?.isOpen &&" not in content:
        modal_ui = """
      {promptConfig?.isOpen && (
        <div style={{ position: "fixed", top: 0, left: 0, right: 0, bottom: 0, background: "rgba(255,255,255,0.4)", backdropFilter: "blur(20px)", WebkitBackdropFilter: "blur(20px)", display: "flex", justifyContent: "center", alignItems: "center", zIndex: 1000}}>
          <div style={{ background: "rgba(255,255,255,0.85)", padding: "24px", borderRadius: "24px", width: "360px", maxWidth: "90%", boxShadow: "0 25px 50px rgba(0,0,0,0.1)", border: "1px solid rgba(255,255,255,0.6)", textAlign: "center" }}>
             <p style={{ margin: "0 0 20px 0", fontWeight: 600, fontSize: "16px", color: "#1d1d1f" }}>
               {promptConfig.title}
             </p>
             <input 
               type="text" 
               id="custom-prompt-input"
               defaultValue={promptConfig.defaultValue}
               style={{ width: "100%", padding: "12px", marginBottom: "20px", boxSizing: "border-box", borderRadius: "10px", border: "1px solid rgba(0,0,0,0.1)", background: "rgba(255,255,255,0.8)", outline: "none", fontSize: "15px", transition: "all 0.3s ease" }}
               onFocus={(e) => { e.target.style.boxShadow = "0 0 0 4px rgba(0,113,227,0.2)"; e.target.style.borderColor = "#0071e3"; }}
               onBlur={(e) => { e.target.style.boxShadow = "none"; e.target.style.borderColor = "rgba(0,0,0,0.1)"; }}
             />
             <div style={{ display: "flex", gap: "10px", justifyContent: "center" }}>
               <button 
                 onClick={() => setPromptConfig(null)} 
                 style={{ flex: 1, padding: "10px 0", background: "none", color: "#0071e3", border: "1px solid rgba(0,113,227,0.3)", borderRadius: "20px", cursor: "pointer", fontSize: "15px", fontWeight: 500, transition: "all 0.2s" }}
                 onMouseOver={(e) => e.currentTarget.style.background = "rgba(0,113,227,0.1)"}
                 onMouseOut={(e) => e.currentTarget.style.background = "none"}
               >
                 Cancelar
               </button>
               <button 
                 onClick={() => {
                   const val = (document.getElementById("custom-prompt-input") as HTMLInputElement).value;
                   promptConfig.onConfirm(val);
                   setPromptConfig(null);
                 }} 
                 style={{ flex: 1, padding: "10px 0", background: "#0071e3", color: "white", border: "none", borderRadius: "20px", cursor: "pointer", fontSize: "15px", fontWeight: 500, transition: "all 0.2s" }}
                 onMouseOver={(e) => e.currentTarget.style.transform = "scale(0.96)"}
                 onMouseOut={(e) => e.currentTarget.style.transform = "scale(1)"}
               >
                 Aceptar
               </button>
             </div>
          </div>
        </div>
      )}
"""
        content = content.replace("    </div>\n  );\n}\n", modal_ui + "\n    </div>\n  );\n}\n")

    # Replace the inline prompts with setPromptConfig
    # For + Horas
    code_plus_old = """const hours = prompt("¿Cuántas horas adicionales usaste en esta tarea?", "1");
                                    if (hours) {
                                      const parsed = parseFloat(hours);
                                      if (!isNaN(parsed)) {
                                        tasksApi.update(task.id, { spent_hours: Math.max(0, (task.spent_hours || 0) + parsed) })
                                          .then(fetchTasksData)
                                          .catch(console.error);
                                      }
                                    }"""
    code_plus_new = """setPromptConfig({
                                      isOpen: true,
                                      title: "¿Cuántas horas adicionales usaste en esta tarea?",
                                      defaultValue: "1",
                                      onConfirm: (hours) => {
                                        if (hours) {
                                          const parsed = parseFloat(hours);
                                          if (!isNaN(parsed)) {
                                            tasksApi.update(task.id, { spent_hours: Math.max(0, (task.spent_hours || 0) + parsed) })
                                              .then(fetchTasksData)
                                              .catch(console.error);
                                          }
                                        }
                                      }
                                    });"""
    content = content.replace(code_plus_old, code_plus_new)

    # For - Horas
    code_min_old = """const hours = prompt("¿Cuántas horas deseas restar de esta tarea?", "1");
                                    if (hours) {
                                      const parsed = parseFloat(hours);
                                      if (!isNaN(parsed)) {
                                        tasksApi.update(task.id, { spent_hours: Math.max(0, (task.spent_hours || 0) - parsed) })
                                          .then(fetchTasksData)
                                          .catch(console.error);
                                      }
                                    }"""
    code_min_new = """setPromptConfig({
                                      isOpen: true,
                                      title: "¿Cuántas horas deseas restar de esta tarea?",
                                      defaultValue: "1",
                                      onConfirm: (hours) => {
                                        if (hours) {
                                          const parsed = parseFloat(hours);
                                          if (!isNaN(parsed)) {
                                            tasksApi.update(task.id, { spent_hours: Math.max(0, (task.spent_hours || 0) - parsed) })
                                              .then(fetchTasksData)
                                              .catch(console.error);
                                          }
                                        }
                                      }
                                    });"""
    content = content.replace(code_min_old, code_min_new)

    # Beautify the buttons "+ Horas" and "- Horas"
    content = content.replace("""background: "#17a2b8", color: "white", border: "none", padding: "5px 8px", borderRadius: "3px", cursor: "pointer", fontSize:"12px" """, """background: "rgba(0,113,227,0.1)", color: "#0071e3", border: "none", padding: "5px 10px", borderRadius: "12px", cursor: "pointer", fontSize:"12px", fontWeight:500 """)
    content = content.replace("""background: "#dc3545", color: "white", border: "none", padding: "5px 8px", borderRadius: "3px", cursor: "pointer", fontSize:"12px" """, """background: "rgba(255,59,48,0.1)", color: "#ff3b30", border: "none", padding: "5px 10px", borderRadius: "12px", cursor: "pointer", fontSize:"12px", fontWeight:500 """)

    with open(file_path, "w") as f:
        f.write(content)
        
apply_patch()
EOF
