cat << 'EOF' > apply_glassmorphism.py
import re
import glob

# Recursive search for all page.tsx files
files = glob.glob("frontend/app/**/page.tsx", recursive=True)

for f in files:
    with open(f, "r") as file:
        content = file.read()

    # 1. Background standard list or boards
    content = re.sub(
        r'backgroundColor:\s*"#f1f5f9"',
        r'backgroundColor: "rgba(255, 255, 255, 0.4)", backdropFilter: "blur(20px)", WebkitBackdropFilter: "blur(20px)"',
        content
    )

    # 2. Main content cards (white backgrounds) -> Glassmorphism
    content = re.sub(
        r'background:\s*"white",\s*padding:\s*"20px",\s*margin:\s*"16px 0",\s*borderRadius:\s*"12px",\s*border:\s*"1px solid #e2e8f0",\s*boxShadow:\s*"0 4px 6px -1px rgba\(0,0,0,0\.1\), 0 2px 4px -1px rgba\(0,0,0,0\.06\)"',
        r'background: "rgba(255, 255, 255, 0.7)", padding: "24px", margin: "16px 0", borderRadius: "20px", border: "1px solid rgba(255,255,255,0.6)", boxShadow: "0 8px 32px rgba(0,0,0,0.06)", backdropFilter: "blur(20px)", WebkitBackdropFilter: "blur(20px)"',
        content
    )
    
    # login/register inputs specifically
    content = re.sub(
        r'background:\s*"white",\s*padding:\s*"40px",\s*borderRadius:\s*"8px",\s*boxShadow:\s*"0 4px 6px -1px #ccc"',
        r'background: "rgba(255,255,255,0.85)", padding: "40px", borderRadius: "24px", border: "1px solid rgba(255,255,255,0.4)", boxShadow: "0 24px 48px rgba(0,0,0,0.12)", backdropFilter: "blur(40px) saturate(150%)", WebkitBackdropFilter: "blur(40px) saturate(150%)"',
        content
    )

    # 3. Inner task cards
    content = re.sub(
        r'background:\s*"#f8fafc",\s*padding:\s*"12px",\s*borderRadius:\s*"8px",\s*marginBottom:\s*"12px",\s*border:\s*"1px solid #e2e8f0"',
        r'background: "rgba(255, 255, 255, 0.95)", padding: "16px", borderRadius: "16px", marginBottom: "12px", border: "1px solid rgba(255,255,255,0.8)", boxShadow: "0 4px 12px rgba(0,0,0,0.04)"',
        content
    )

    # 4. Modals and Overlays
    content = re.sub(
        r'background:\s*"rgba\(0,0,0,0\.5\)"',
        r'background: "rgba(0,0,0,0.2)", backdropFilter: "blur(8px)", WebkitBackdropFilter: "blur(8px)"',
        content
    )
    
    # 5. Modal Boxes
    content = re.sub(
        r'background:\s*"white",\s*padding:\s*"30px",\s*borderRadius:\s*"16px",\s*width:\s*"450px",\s*boxShadow:\s*"0 20px 25px -5px rgba\(0, 0, 0, 0\.1\), 0 10px 10px -5px rgba\(0, 0, 0, 0\.04\)"',
        r'background: "rgba(255, 255, 255, 0.85)", padding: "32px", borderRadius: "24px", width: "450px", boxShadow: "0 24px 48px rgba(0,0,0,0.12)", backdropFilter: "blur(40px) saturate(150%)", WebkitBackdropFilter: "blur(40px) saturate(150%)", border: "1px solid rgba(255,255,255,0.5)"',
        content
    )
    
    # 6. Button Colors
    content = content.replace('"#2563eb"', '"#0071e3"').replace('"#10b981"', '"#34c759"').replace('"#ef4444"', '"#ff3b30"')
    
    # Layout background gradient maybe? We can inject a cool apple background in the body via global, but let's stick to the main div replacing if possible.
    # Check if there is an outer div that doesn't have a background but wraps the content
    
    with open(f, "w") as file:
        file.write(content)

EOF
