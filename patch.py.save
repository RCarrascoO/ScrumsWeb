import os

files = [
    "frontend/app/layout.tsx",
    "frontend/app/login/page.tsx",
    "frontend/app/register/page.tsx",
    "frontend/app/dashboard/page.tsx",
    "frontend/app/projects/[id]/page.tsx",
    "frontend/app/projects/[id]/sprints/[sprintId]/page.tsx",
    "frontend/app/page.tsx"
]

layout_css_old = '''        <style dangerouslySetInnerHTML={{__html: `
          body {
            margin: 0;
            padding: 0;
            font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, "Helvetica Neue", Arial, sans-serif;
            background-color: #f8fafc;
            color: #0f172a;
          }
          button {
            font-family: inherit;
            transition: all 0.2s ease-in-out;
          }
          button:hover {
            transform: translateY(-1px);
            box-shadow: 0 4px 6px -1px rgba(0,0,0,0.1), 0 2px 4px -1px rgba(0,0,0,0.06);
          }
          input, select {
            font-family: inherit;
            border: 1px solid #e2e8f0;
            outline: none;
            transition: border-color 0.2s ease-in-out, box-shadow 0.2s ease-in-out;
          }
          input:focus, select:focus {
            border-color: #3b82f6;
            box-shadow: 0 0 0 3px rgba(59, 130, 246, 0.2);
          }
          a {
            color: #2563eb;
            text-decoration: none;
          }
          a:hover {
            text-decoration: underline;
          }
        `}} />'''

layout_css_new = '''        <style dangerouslySetInnerHTML={{__html: `
          body {
            margin: 0;
            padding: 0;
            font-family: -apple-system, BlinkMacSystemFont, "SF Pro Display", "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
            background-color: #f5f5f7;
            color: #1d1d1f;
            -webkit-font-smoothing: antialiased;
          }
          button {
            font-family: inherit;
            transition: all 0.3s cubic-bezier(0.25, 0.8, 0.25, 1);
            border-radius: 12px !important;
          }
          button:hover {
            transform: scale(1.02);
            box-shadow: 0 8px 16px rgba(0,0,0,0.08);
          }
          button:active {
            transform: scale(0.98);
          }
          input, select {
            font-family: inherit;
            border: 1px solid rgba(0,0,0,0.1);
            border-radius: 12px !important;
            outline: none;
            background: rgba(255,255,255,0.8);
            backdrop-filter: blur(10px);
            transition: all 0.3s ease;
          }
          input:focus, select:focus {
            border-color: #0071e3;
            box-shadow: 0 0 0 4px rgba(0, 113, 227, 0.15);
            background: #fff;
          }
          a {
            color: #0071e3;
            text-decoration: none;
            transition: opacity 0.2s ease;
          }
          a:hover {
            opacity: 0.8;
          }
          
          /* Apple-like scrollbar */
          ::-webkit-scrollbar {
            width: 8px;
            height: 8px;
          }
          ::-webkit-scrollbar-track {
            background: transparent;
          }
          ::-webkit-scrollbar-thumb {
            background-color: rgba(0,0,0,0.2);
            border-radius: 10px;
          }
          ::-webkit-scrollbar-thumb:hover {
            background-color: rgba(0,0,0,0.3);
          }
        `}} />'''

for f in files:
    if os.path.exists(f):
        with open(f, "r") as file:
            content = file.read()
        
        if "layout.tsx" in f:
            content = content.replace(layout_css_old, layout_css_new)
            
        # Refine common card components for Glassmorphism/premium look
        content = content.replace(
            'background: "white", padding: "20px", margin: "16px 0", borderRadius: "12px", border: "1px solid #e2e8f0", boxShadow: "0 4px 6px -1px rgba(0,0,0,0.1), 0 2px 4px -1px rgba(0,0,0,0.06)"',
            'background: "rgba(255, 255, 255, 0.75)", padding: "24px", margin: "16px 0", borderRadius: "20px", border: "1px solid rgba(255, 255, 255, 0.4)", boxShadow: "0 10px 30px rgba(0,0,0,0.04), 0 1px 2px rgba(0,0,0,0.02)", backdropFilter: "blur(20px)"'
        )

        content = content.replace(
            'backgroundColor: "#f1f5f9", padding: "20px", borderRadius: "16px", border: "1px solid #e2e8f0"',
            'backgroundColor: "rgba(240, 240, 245, 0.6)", padding: "24px", borderRadius: "24px", border: "1px solid rgba(0,0,0,0.03)", backdropFilter: "blur(10px)"'
        )

        # Modals
        content = content.replace(
            'background: "white", padding: "30px", borderRadius: "16px", width: "450px", boxShadow: "0 20px 25px -5px rgba(0, 0, 0, 0.1), 0 10px 10px -5px rgba(0, 0, 0, 0.04)"',
            'background: "rgba(255, 255, 255, 0.85)", padding: "32px", borderRadius: "24px", width: "450px", boxShadow: "0 24px 48px rgba(0,0,0,0.12), 0 0 1px rgba(0,0,0,0.1)", backdropFilter: "blur(40px) saturate(150%)", border: "1px solid rgba(255,255,255,0.5)"'
        )

        # Buttons
        content = content.replace('background: "#2563eb", boxShadow: "0 1px 2px rgba(0,0,0,0.05)"', 'background: "#0071e3", color: "white", fontWeight: "500"')
        content = content.replace('background: "#10b981"', 'background: "#34c759", color: "white", fontWeight: "500"')
        content = content.replace('background: "#ef4444"', 'background: "#ff3b30", color: "white", fontWeight: "500"')
        content = content.replace('background: "#0ea5e9"', 'background: "#5ac8fa", color: "white", fontWeight: "500"')
        content = content.replace('background: "#e2e8f0", color: "#334155"', 'background: "#e5e5ea", color: "#1d1d1f", fontWeight: "500"')

        # Kanban Sprint details specifically
        content = content.replace(
            'border: "1px solid #e2e8f0"',
            'border: "1px solid rgba(0, 0, 0, 0.04)"'
        )
        content = content.replace(
            'background: "#f8fafc"',
            'background: "rgba(255, 255, 255, 0.6)", backdropFilter: "blur(10px)"'
        )

        # Header adjustments
        content = content.replace(
            'borderBottom: "1px solid #ccc"',
            'borderBottom: "1px solid rgba(0,0,0,0.06)"'
        )
        
        content = content.replace(
            'background: "rgba(0,0,0,0.5)"',
            'background: "rgba(0,0,0,0.25)", backdropFilter: "blur(5px)"'
        )


        with open(f, "w") as file:
            file.write(content)
