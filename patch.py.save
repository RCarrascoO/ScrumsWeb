                              {isManagerOrAdmin && (
                                <button onClick={() => setShowAssignModalForTask(task.id)} style={{ background: "transparent", border: "1px solid #cbd5e1", borderRadius: "4px", fontSize:"11px", padding: "3px 8px", cursor: "pointer", color: "#475569" }}>Reasignar</button>
                              )}
                          </div>
                          <div style={{ display: "flex", justifyContent: "space-between", color: "#64748b" }}>
                            <span><b>Prioridad:</b> <span style={{ padding: "2px 6px", borderRadius: "12px", background: task.priority === "CRITICAL" || task.priority === "HIGH" ? "#fee2e2" : "#f1f5f9", color: task.priority === "CRITICAL" || task.priority === "HIGH" ? "#ef4444" : "#334155" }}>{task.priority}</span></span>
                            <span>{task.spent_hours || 0}h / {task.estimate_hours || 0}h</span>
                          </div>
                        </div>"""

content = content.replace(card_structure_old, card_structure_new)

# Improve buttons inside cards
buttons_old = """                           <div style={{ marginLeft: "auto" }}>
                              {statusGroup === "TODO" && <button onClick={() => updateTaskStatus(task.id, "IN_PROGRESS", task.assignee_id)} style={{ fontSize:"12px" }}>En Progreso →</button>}
                              {statusGroup === "IN_PROGRESS" && (
                                 <>
                                   <button onClick={() => updateTaskStatus(task.id, "TODO", task.assignee_id)} style={{ fontSize:"12px" }}>← TODO</button>
                                   <button onClick={() => updateTaskStatus(task.id, "DONE", task.assignee_id)} style={{ marginLeft: "5px", fontSize:"12px" }}>Terminar →</button>
                                 </>
                              )}
                              {statusGroup === "DONE" && <button onClick={() => updateTaskStatus(task.id, "IN_PROGRESS", task.assignee_id)} style={{ fontSize:"12px" }}>← En Progreso</button>}
                           </div>"""

buttons_new = """                           <div style={{ marginLeft: "auto", display: "flex", gap: "6px" }}>
                              {statusGroup === "TODO" && <button onClick={() => updateTaskStatus(task.id, "IN_PROGRESS", task.assignee_id)} style={{ fontSize:"12px", padding: "6px 12px", background: "#3b82f6", color: "white", border: "none", borderRadius: "4px", cursor: "pointer" }}>En Progreso →</button>}
                              {statusGroup === "IN_PROGRESS" && (
                                 <>
                                   <button onClick={() => updateTaskStatus(task.id, "TODO", task.assignee_id)} style={{ fontSize:"12px", padding: "6px 12px", background: "#f1f5f9", color: "#334155", border: "none", borderRadius: "4px", cursor: "pointer" }}>← TODO</button>
                                   <button onClick={() => updateTaskStatus(task.id, "DONE", task.assignee_id)} style={{ fontSize:"12px", padding: "6px 12px", background: "#10b981", color: "white", border: "none", borderRadius: "4px", cursor: "pointer" }}>Terminar ✓</button>
                                 </>
                              )}
                              {statusGroup === "DONE" && <button onClick={() => updateTaskStatus(task.id, "IN_PROGRESS", task.assignee_id)} style={{ fontSize:"12px", padding: "6px 12px", background: "#f1f5f9", color: "#334155", border: "none", borderRadius: "4px", cursor: "pointer" }}>← En Progreso</button>}
                           </div>"""

content = content.replace(buttons_old, buttons_new)

with open(path, 'w') as f:
    f.write(content)
EOF
