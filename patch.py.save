          <div style={{ background: "rgba(255,255,255,0.85)", padding: "24px", borderRadius: "24px", width: "400px", maxWidth: "90%", maxHeight: "80vh", overflowY: "auto", boxShadow: "0 25px 50px rgba(0,0,0,0.1)", border: "1px solid rgba(255,255,255,0.6)" }}>'''
    
