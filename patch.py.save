import re

files = [
    "frontend/app/login/page.tsx",
    "frontend/app/register/page.tsx",
    "frontend/app/dashboard/page.tsx",
    "frontend/app/projects/[id]/page.tsx",
    "frontend/app/projects/[id]/sprints/[sprintId]/page.tsx"
]

for f in files:
    try:
        with open(f, 'r') as fp:
            content = fp.read()
        
        # General background
        content = content.replace('backgroundColor: "#f1f5f9"', 'background: "rgba(255, 255, 255, 0.4)", backdropFilter: "blur(20px)", WebkitBackdropFilter: "blur(20px)"')
        # Main cards
        content = content.replace('background: "white", padding: "20px", margin: "16px 0", borderRadius: "12px", border: "1px solid #e2e8f0", boxShadow: "0 4px 6px -1px rgba(0,0,0,0.1), 0 2px 4px -1px rgba(0,0,0,0.06)"', 
                                  'background: "rgba(255, 255, 255, 0.65)", padding: "24px", margin: "16px 0", borderRadius: "20px", border: "1px solid rgba(255, 255, 255, 0.4)", boxShadow: "0 8px 32px rgba(0,0,0,0.06)", backdropFilter: "blur(24px)", WebkitBackdropFilter: "blur(24px)"')
                                  
        # Inner kanban tasks
        content = content.replace('background: "#f8fafc", padding: "12px", borderRadius: "8px", marginBottom: "12px", border: "1px solid #e2e8f0"',
                                  'background: "rgba(255, 255, 255, 0.9)", padding: "16px", borderRadius: "16px", marginBottom: "12px", border: "1px solid rgba(255,255,255,0.8)", boxShadow: "0 4px 12px rgba(0,0,0,0.04)"')

        # Modals container
        content = content.replace('background: "rgba(0,0,0,0.5)"', 'background: "rgba(0,0,0,0.2)", backdropFilter: "blur(8px)", WebkitBackdropFilter: "blur(8px)"')
        # Modal Inner
        content = content.replace('background: "white", padding: "30px", borderRadius: "16px", width: "450px", boxShadow: "0 20px 25px -5px rgba(0, 0, 0, 0.1), 0 10px 10px -5px rgba(0, 0, 0, 0.04)"',
                                  'background: "rgba(255, 255, 255, 0.85)", padding: "32px", borderRadius: "24px", width: "450px", boxShadow: "0 24px 48px rgba(0,0,0,0.12)", backdropFilter: "blur(40px) saturate(150%)", border: "1px solid rgba(255, 255, 255, 0.5)"')

        # Buttons
        content = content.replace('background: "#3b82f6", color: "white"', 'background: "#0071e3", color: "white", fontWeight: "500"')
        content = content.replace('background: "#2563eb"', 'background: "#0071e3"')
        content = content.replace('background: "#10b981"', 'background: "#34c759"')
        content = content.replace('background: "#ef4444"', 'background: "#ff3b30"')
        
        with open(f, 'w') as fp:
            fp.write(content)
    except FileNotFoundError:
        pass
