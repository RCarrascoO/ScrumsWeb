    new_btn_elegir = '''<button onClick={() => handleAssignTask(showAssignModalForTask, u.email)} style={{ background: "#34c759", color: "white", border: "none", padding: "6px 14px", borderRadius: "14px", cursor: "pointer", fontSize: "13px", fontWeight: 500, transition: "all 0.2s" }} onMouseOver={(e) => e.currentTarget.style.transform = "scale(0.96)"} onMouseOut={(e) => e.currentTarget.style.transform = "scale(1)"}>Elegir</button>'''
    if old_btn_elegir in content:
        content = content.replace(old_btn_elegir, new_btn_elegir)

    # Button Cancelar
    old_btn_cancel = '''<button onClick={() => setShowAssignModalForTask(null)} style={{ marginTop: "15px", width: "100%", background: "#ccc", border: "none", padding: "8px", borderRadius: "4px", cursor: "pointer" }}>Cancelar</button>'''
